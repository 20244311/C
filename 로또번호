#include <stdio.h>
#include <stdlib.h>
#include <time.h>
int main(void)
{
	int s;
	printf("Enter lotto set number : ");
	scanf("%d", &s);
	int lotto[s][6];
	srand(time(NULL));
	for(int j = 0; j < s; j++)
		for(int i = 0; i < 6; i++)
			lotto[j][i] = rand() % 45 + 1;		
	for(int j = 0; j < s; j++)
	{
		printf("set %d : ", j+1);
		for(int i = 0; i < 6; i++)
			printf("%d ", lotto[j][i]);
		printf("\n");
	}
	return 0;
}
